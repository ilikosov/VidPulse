generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Channel {
  id                 String   @id
  title              String
  uploadsPlaylistId  String
  lastSyncedAt       DateTime?
  videos             Video[]
}

model Video {
  id          String   @id
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id])
  title       String
  publishedAt DateTime
  createdAt   DateTime @default(now())

  @@index([channelId])
  @@index([publishedAt])
}
