{
  "name": "@vidpulse/api",
  "version": "0.1.0",
  "description": "Fastify API server for VidPulse",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node -r tsx/register src/db/migrate.ts",
    "db:generate": "prisma generate",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^8.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/rate-limit": "^8.0.0",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^1.0.0",
    "@prisma/client": "^5.0.0",
    "@vidpulse/shared": "workspace:*",
    "bullmq": "^5.0.0",
    "dotenv": "^16.0.0",
    "fastify": "^4.0.0",
    "ioredis": "^5.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prisma": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}